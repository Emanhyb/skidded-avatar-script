local SelectedAccessories = {}
local SelectedHead = nil

---------------------------------------------------------------------
-- APPLY
---------------------------------------------------------------------

local function ApplySelected()

	local character = LocalPlayer.Character
	if not character then return end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local currentDesc = humanoid:GetAppliedDescription()

	local accessories = {}

	for _,id in ipairs(SelectedAccessories) do
		accessories[tostring(id)] = id
	end

	local args = {
		{
			BodyParts = {

				Head = SelectedHead or currentDesc.Head,

				Torso = currentDesc.Torso,
				LeftArm = currentDesc.LeftArm,
				RightArm = currentDesc.RightArm,
				LeftLeg = currentDesc.LeftLeg,
				RightLeg = currentDesc.RightLeg
			},

			Accessories = accessories,

			Shirt = currentDesc.Shirt,
			Pants = currentDesc.Pants,
			Face = currentDesc.Face,
			TShirt = currentDesc.GraphicTShirt
		}
	}

	ReplicatedStorage:WaitForChild("AvatarRemotes")
	:WaitForChild("ApplyDescription")
	:FireServer(unpack(args))

	task.wait(0.4)

	local char = LocalPlayer.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.Health = 0
		end
	end
end

