	knob.BackgroundColor3 = Color3.new(1,1,1)

	Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

	local function Toggle()

		enabled = not enabled

		if enabled then

			slider.BackgroundColor3 = Color3.fromRGB(0,200,120)
			knob.Position = UDim2.new(1,-20,0.5,-9)

			if item.Head then
				SelectedHead = item.Head
			end

			for _,id in ipairs(item.Accessories) do
				table.insert(SelectedAccessories,id)
			end

		else

			slider.BackgroundColor3 = Color3.fromRGB(50,50,50)
			knob.Position = UDim2.new(0,2,0.5,-9)

			for _,id in ipairs(item.Accessories) do

				for i,v in ipairs(SelectedAccessories) do
					if v == id then
						table.remove(SelectedAccessories,i)
						break
					end
				end
			end
		end
	end

	holder.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			Toggle()
		end
	end)
end

